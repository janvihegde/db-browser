{
  "manifest_version": 3,
  "name": "DB Browser Local Connector",
  "version": "0.1.0",
  "description": "Lets the DB Browser web app talk to a local PostgreSQL database via a native messaging host running on your machine.",

  "permissions": [
    "nativeMessaging"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://YOUR-APP.vercel.app/*",
        "http://localhost:5173/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
