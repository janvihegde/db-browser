{
  "manifest_version": 3,
  "name": "DB Browser Local Bridge",
  "version": "1.0.0",
  "description": "Lets db-browser-one.vercel.app talk to databases on your own machine.",
  "key": "",
  "permissions": ["nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://db-browser-one.vercel.app/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}