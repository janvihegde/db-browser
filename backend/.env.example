# Copy this to .env for local dev and fill in real values.
# In Render, set these as actual Environment Variables instead — never commit real values.

DB_USER=
DB_HOST=
DB_NAME=
DB_PASSWORD=
DB_PORT=5432

# Set to true once you have the RDS CA bundle wired in; false disables cert validation (dev only)
DB_SSL_REJECT_UNAUTHORIZED=false

# Generate with: openssl rand -base64 32
JWT_SECRET=

# Your deployed frontend URL, e.g. https://db-browser.vercel.app
CORS_ORIGIN=http://localhost:5173

# Max Postgres connections this process opens. If you ever run N instances,
# N x DB_POOL_MAX must stay under your RDS max_connections.
DB_POOL_MAX=10

NODE_ENV=development
